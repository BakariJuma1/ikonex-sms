{
  "name": "ikonex-sms-server",
  "version": "1.0.0",
  "description": "ikonex SMS backend API",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "test": "jest --forceExit --runInBand",
    "test:coverage": "jest --coverage --forceExit --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"]
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  }
}
